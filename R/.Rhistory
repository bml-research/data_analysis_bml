names = barplot_data$day,
col = "steelblue",
main = "Lab samples processed in the week")
barplot(summ_data$`Birth weight (g)`,
ylab = "Birth weight (g)",
ylim = c(0, max(summ_data$`Birth weight (g)` + 100)),
names = summ_data$`Common name`,
las = 2,
cex.names = 0.5,
col = "steelblue",
main = "Birth weight for different cat species")
p <- barplot_data %>%
ggplot(aes(x = day, y = samples_processed)) +
geom_bar(stat="identity", fill="steelblue") +
labs(title="Lab samples processed in the week") #+
p
